{
  "id": "prompt-webhook-no-network",
  "version": "0.1.0",
  "displayName": "Prompt Webhook No Network",
  "description": "Webhook without capability should fail.",
  "kind": "lifecycle",
  "hooks": [
    "beforeAdapterExecute"
  ],
  "capabilities": [
    "emit_audit"
  ],
  "runtime": {
    "type": "prompt",
    "entrypoint": "prompt:inline",
    "timeoutMs": 5000,
    "retryCount": 0,
    "promptTemplate": "noop"
  }
}