{
  "name": "bopodev-workspace",
  "version": "0.1.32",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "predev": "node scripts/dev-banner.mjs",
    "dev": "node scripts/dev-runner.mjs",
    "dev:full": "turbo --no-update-notifier dev",
    "start": "node scripts/start-runner.mjs",
    "start:quiet": "node scripts/start-runner.mjs --quiet",
    "build": "turbo build",
    "db:generate": "pnpm --filter bopodev-db generate",
    "db:migrate": "pnpm --filter bopodev-db migrate",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "onboard": "node scripts/cli-runner.mjs onboard",
    "doctor": "node scripts/cli-runner.mjs doctor",
    "upgrade:local": "node scripts/cli-runner.mjs upgrade",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clear": "node scripts/clear.mjs",
    "unstick": "node scripts/unstick.mjs",
    "smoke:vps": "sh scripts/smoke-vps.sh",
    "publish:all:only": "pnpm -r --filter bopodev-contracts --filter bopodev-db --filter bopodev-agent-sdk --filter bopodev-ui --filter bopodev-api --filter bopodev publish --access public --no-git-checks",
    "publish:all": "pnpm build && pnpm run publish:all:only",
    "publish:all:dry": "pnpm build && pnpm run publish:all:only -- --dry-run"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.3.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "turbo": "^2.8.14",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@tlbt/cli": "^0.0.5"
  }
}
